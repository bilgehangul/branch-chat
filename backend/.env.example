# Gemini AI provider
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily web search
TAVILY_API_KEY=your_tavily_api_key_here

# Google OAuth (audience for ID token verification)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Provider selection — "gemini" (default) or "openai" (stub only in Phase 1)
AI_PROVIDER=gemini

# Server
PORT=3001

# CORS — frontend origin (Vite dev server or Vercel URL)
CLIENT_ORIGIN=http://localhost:5173

MONGODB_URI=