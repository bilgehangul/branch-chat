# .env.example — at repository root
# Copy to backend/.env and frontend/.env.local and fill in values.
# Never commit .env or .env.local to version control.

# === BACKEND (backend/.env) ===

# Port the Express server listens on
PORT=3001

# Google OAuth client ID — get from Google Cloud Console > Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# Gemini API key — get from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=AIza...

# Tavily API key — get from tavily.com
TAVILY_API_KEY=tvly-...

# AI provider selection — "gemini" or "openai"
AI_PROVIDER=gemini

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@YOUR_CLUSTER.mongodb.net/deepdive?retryWrites=true&w=majority

# Frontend origin for CORS — must match exactly (no trailing slash)
# Development: http://localhost:5173
# Production (AWS EC2): http://YOUR_EC2_PUBLIC_IP
CLIENT_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development

# === FRONTEND (frontend/.env.local) ===

# Google OAuth client ID — same as backend GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# Backend API base URL — prefix for all /api/* fetch calls
# Development: leave empty (Vite proxy handles /api → localhost:3001)
# Production (AWS EC2): leave empty (nginx proxies /api → localhost:3001)
VITE_API_BASE_URL=
